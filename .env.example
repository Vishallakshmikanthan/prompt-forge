# PROMPTFORGE ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env in both root, /frontend, and /backend as needed.

# ─── FRONTEND (Next.js) ──────────────────────────────────────────────────────
# The URL of your deployed backend API (e.g., https://api.promptforge.com/api)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Supabase configuration for authentication and storage
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── BACKEND (Express) ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# The URL of your deployed frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Use a managed PostgreSQL (Supabase, Neon, Railway, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="postgresql://user:password@localhost:5432/promptforge_db?schema=public"

# ─── SEARCH & SERVICES ───────────────────────────────────────────────────────
# Meilisearch configuration
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=your_meilisearch_master_key

# Optional: Sentry for monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# IndexNow key for search engine pinging
INDEXNOW_KEY=your-indexnow-key-here
