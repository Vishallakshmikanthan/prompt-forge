// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  displayName   String?
  reputation    Int            @default(0)
  bio           String?
  avatarUrl     String?
  githubUrl     String?
  website       String?
  location      String?
  skills        Json?
  provider      String         @default("google")
  password_hash String?
  created_at    DateTime       @default(now())
  prompts       Prompt[]
  votes         Vote[]
  bookmarks     Bookmark[]
  notifications Notification[]
  discussions   Discussion[]
  forks         PromptFork[]

  @@map("users")
}

model Prompt {
  id               String           @id @default(cuid())
  title            String
  description      String
  promptContent    String
  category         String
  aiModel          String
  tags             String[]
  score            Int              @default(0)
  moderationStatus String           @default("approved")
  qualityScore     Int?
  createdAt        DateTime         @default(now())
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  parentPromptId   String?
  parentPrompt     Prompt?          @relation("PromptLineage", fields: [parentPromptId], references: [id])
  forkedPrompts    Prompt[]         @relation("PromptLineage")
  embedding        Float[]
  versions         PromptVersion[]
  votes            Vote[]
  bookmarks        Bookmark[]
  analytics        PromptAnalytics?
  forkEvents       PromptFork[]     @relation("PromptForks")

  @@index([category])
  @@index([moderationStatus])
  @@index([createdAt])
}

model PromptAnalytics {
  id        String   @id @default(cuid())
  promptId  String   @unique
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  views     Int      @default(0)
  votes     Int      @default(0)
  forks     Int      @default(0)
  bookmarks Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt
}

model PromptVersion {
  id            String   @id @default(cuid())
  versionNumber Int
  promptContent String
  createdAt     DateTime @default(now())
  promptId      String
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
}

model Vote {
  id       String @id @default(cuid())
  voteType String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
  @@index([userId])
  @@index([promptId])
}

model Bookmark {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
  @@index([userId])
  @@index([promptId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Discussion {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  content   String
  category  String
  tags      String[]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upvotes   Int      @default(0)
  comments  Int      @default(0)
  trending  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([category])
}

model PromptFork {
  id             String   @id @default(cuid())
  promptId       String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  originalPrompt Prompt   @relation("PromptForks", fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([userId])
}
